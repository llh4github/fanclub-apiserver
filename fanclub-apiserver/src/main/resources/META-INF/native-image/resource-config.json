{
  "resources": {
    "includes": [
      {
        "pattern": ".*\\.xml"
      },
      {
        "pattern": "\\QMETA-INF/jimmer/code_generation\\E"
      },
      {
        "pattern": "\\QMETA-INF/jimmer/client\\E"
      },
      {
        "pattern": "\\QMETA-INF/jimmer/entities\\E"
      },
      {
        "pattern": ".*\\.properties"
      },
      {
        "pattern": ".*\\.ttf"
      },
      {
        "pattern": ".*\\.otf"
      }
    ]
  },
  "bundles": [
    {
      "name": "sun.awt.resources.awt",
      "locales": [
        ""
      ]
    }
  ]
}
# 使用方法:
# 1. 复制此文件为 .env
# 2. 根据实际环境修改相应的配置值
# 3. 确保敏感信息(如密码)不要提交到版本控制系统

# 应用程序配置
FANCLUB_APP_NAME=fanclub-vup

# 数据库配置
FANCLUB_DATASOURCE_URL=jdbc:mariadb://localhost:3306/fanclub_dev
FANCLUB_DATASOURCE_USERNAME=root
FANCLUB_DATASOURCE_PASSWORD=123456

# Redis配置
FANCLUB_REDIS_HOST=localhost
FANCLUB_REDIS_PORT=6379
FANCLUB_REDIS_DATABASE=0
FANCLUB_REDIS_PASSWORD=

# 日志配置
FANCLUB_LOG_LEVEL=INFO

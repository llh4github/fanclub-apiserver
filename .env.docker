# Docker Compose 环境变量配置
# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fanclub_dev
DB_USERNAME=root
DB_PASSWORD=123456

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=123456


# 应用配置
FANCLUB_APP_NAME=fanclub-vup
FANCLUB_SHOW_SQL=true
FANCLUB_SWAGGER_ENABLED=true
FANCLUB_LOG_LEVEL=debug
FANCLUB_SPRING_LOG_LEVEL=debug
